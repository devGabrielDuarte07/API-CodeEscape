  "components": {
    "schemas": {
      "AtualizarAvatarRequest": {
        "type": "object",
        "properties": {
          "avatarUrl": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "CriarUsuarioRequest": {
        "required": [
          "confirmarSenha",
          "email",
          "nome",
          "senha",
          "username"
        ],
        "type": "object",
        "properties": {
          "nome": {
            "maxLength": 255,
            "minLength": 3,
            "type": "string"
          },
          "username": {
            "maxLength": 50,
            "minLength": 2,
            "pattern": "^[a-zA-Z0-9_]+$",
            "type": "string",
            "default": "Username"
          },
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "senha": {
            "minLength": 1,
            "pattern": "^(?=.*[a-z])(?=.*[A-Z])(?=.*\\d)[A-Za-z\\d!@#$%&*._-]{6,50}$",
            "type": "string"
          },
          "confirmarSenha": {
            "minLength": 1,
            "type": "string"
          },
          "avatarUrl": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "FeedbackRequest": {
        "type": "object",
        "properties": {
          "nome": {
            "type": "string",
            "nullable": true
          },
          "email": {
            "type": "string",
            "nullable": true
          },
          "categoria": {
            "type": "string",
            "nullable": true
          },
          "mensagem": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "LoginRequest": {
        "required": [
          "login",
          "senha"
        ],
        "type": "object",
        "properties": {
          "login": {
            "minLength": 1,
            "type": "string"
          },
          "senha": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "ResponderEnigmaRequest": {
        "type": "object",
        "properties": {
          "resposta": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "StartGameSessionRequest": {
        "type": "object",
        "properties": {
          "roomId": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      }
    },
    "securitySchemes": {
      "Bearer": {
        "type": "http",
        "description": "Digite o token JWT sem 'Bearer'",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "security": [
    {
      "Bearer": [ ]
    }
  ]
